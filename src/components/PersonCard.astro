---
import { ExternalLink, Mail } from 'lucide-astro';
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/paths';

interface Props {
  person: CollectionEntry<'people'>;
}

const { person } = Astro.props;
const { name, role, affiliation, photo, email, website, interests, bio } = person.data;
const displayRole = role === 'Director' || role === 'PI' ? 'Principal Investigator' : role;
const bioText = bio.trim();
const maxBioChars = 190;
const isLongBio = bioText.length > maxBioChars;
const bioPreview = isLongBio ? `${bioText.slice(0, maxBioChars).replace(/\s+\S*$/, '')}...` : bioText;
const visibleInterests = interests.slice(0, 4);
const hiddenInterestCount = interests.length - visibleInterests.length;
---

<article class="card grid h-full grid-rows-[auto_1fr] overflow-hidden">
  <img
    src={withBase(photo)}
    alt={`Photo or profile placeholder for ${name}`}
    class="aspect-square w-full object-cover"
    style="object-position: center 28%;"
    loading="lazy"
    decoding="async"
  />
  <div class="flex h-full flex-col gap-3 p-4">
    <div>
      <h3 class="text-lg font-bold leading-tight text-[rgb(var(--ink))]">{name}</h3>
      <p class="mt-1 text-xs font-bold uppercase tracking-[0.08em] text-[rgb(var(--accent-strong))]">{displayRole}</p>
      <p class="mt-1 text-xs leading-5 text-[rgb(var(--muted))]">{affiliation}</p>
    </div>
    <div class="text-sm leading-6 text-[rgb(var(--muted))]">
      {
        isLongBio ? (
          <details class="group">
            <summary class="block cursor-pointer list-none group-open:hidden">
              <span>
                {bioPreview}{' '}
                <span class="font-semibold text-[rgb(var(--accent-strong))]">read more</span>
              </span>
            </summary>
            <div class="hidden group-open:block">
              <p>{bioText}</p>
              <button type="button" class="mt-2 font-semibold text-[rgb(var(--accent-strong))]" data-close-details>
                show less
              </button>
            </div>
          </details>
        ) : (
          <p>{bioText}</p>
        )
      }
    </div>
    {
      interests.length > 0 && (
        <ul class="flex flex-wrap gap-1.5" aria-label={`${name} research interests`}>
          {visibleInterests.map((interest) => (
            <li class="rounded-md bg-[rgba(var(--accent),0.1)] px-2 py-0.5 text-[0.7rem] font-semibold text-[rgb(var(--accent-strong))]">
              {interest}
            </li>
          ))}
          {hiddenInterestCount > 0 && (
            <li class="rounded-md border border-[rgba(var(--line),0.95)] px-2 py-0.5 text-[0.7rem] font-semibold text-[rgb(var(--muted))]">
              +{hiddenInterestCount} more
            </li>
          )}
        </ul>
      )
    }
    <div class="mt-auto flex flex-wrap gap-3 pt-1 text-sm">
      {
        email && (
          <a href={`mailto:${email}`} class="inline-flex items-center gap-1.5 font-semibold text-[rgb(var(--accent-strong))]">
            <Mail class="size-4" aria-hidden="true" />
            Email
          </a>
        )
      }
      {
        website && (
          <a href={website} class="inline-flex items-center gap-1.5 font-semibold text-[rgb(var(--accent-strong))]">
            <ExternalLink class="size-4" aria-hidden="true" />
            Website
          </a>
        )
      }
    </div>
  </div>
</article>

<style>
  summary::-webkit-details-marker {
    display: none;
  }
</style>

<script>
  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const closeButton = target.closest('[data-close-details]');
    if (!(closeButton instanceof HTMLElement)) return;

    const details = closeButton.closest('details');
    if (details) details.open = false;
  });
</script>
